{
  "name": "hash256-gpu-miner",
  "version": "0.1.0",
  "description": "HASH256 CLI GPU miner for HASH256 proof-of-work with native CUDA/OpenCL kernels and automatic mint transaction submission.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run native:cuda",
    "cli": "npm run native:cuda",
    "native": "node src/native-cli.js",
    "native:cuda": "set MINER_BACKEND=cuda&& node src/native-cli.js",
    "native:opencl": "set MINER_BACKEND=opencl&& node src/native-cli.js",
    "cuda:test": "native\\bin\\hash256-cuda.exe --test",
    "cuda:bench": "native\\bin\\hash256-cuda.exe --bench 10 6144 384 96"
  },
  "dependencies": {
    "ethers": "^6.13.5"
  }
}
